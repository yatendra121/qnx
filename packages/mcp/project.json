{
  "name": "@qnx/mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/mcp/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build:stdio",
        "cwd": "packages/mcp"
      },
      "outputs": ["{workspaceRoot}/packages/mcp/stdio"]
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm publish --no-git-checks",
        "cwd": "packages/mcp/stdio"
      }
    },
    "build:stdio": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "pnpm run build:stdio"
          }
        ],
        "cwd": "packages/mcp"
      },
      "outputs": ["{workspaceRoot}/packages/mcp/stdio"]
    },
    "build:http": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "pnpm run build:http"
          }
        ],
        "cwd": "packages/mcp"
      },
      "outputs": ["{workspaceRoot}/packages/mcp/http"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/mcp"],
      "options": {
        "config": "packages/mcp/vite.config.ts",
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/packages/mcp"
      }
    }
  }
}
