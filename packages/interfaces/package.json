{
  "name": "@qnx/interfaces",
  "description": "Collection of core functions",
  "author": "Yatendra Kushwaha <https://github.com/yatendra121>",
  "version": "0.8.4",
  "license": "MIT",
  "funding": "https://github.com/sponsors/yatendra121",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yatendra121/qnx.git"
  },
  "main": "./dist/interfaces.cjs",
  "module": "./dist/interfaces.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/interfaces.cjs",
      "import": "./dist/interfaces.mjs"
    }
  },
  "unpkg": "./index.iife.js",
  "jsdelivr": "./index.iife.js",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build && dts-bundle-generator --config ./dts-bundle-generator.config.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint:scripts": "eslint . --ext .ts",
    "format:scripts": "prettier . --write",
    "format": "npm run format:scripts"
  },
  "devDependencies": {},
  "peerDependencies": {
    "express": "4.x || 5.x"
  }
}
