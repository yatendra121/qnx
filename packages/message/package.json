{
  "name": "@qnx/message",
  "description": "Collection of utilities of message",
  "author": "Yatendra Kushwaha <https://github.com/yatendra121>",
  "version": "0.8.7",
  "license": "MIT",
  "funding": "https://github.com/sponsors/yatendra121",
  "files": [
    "dist"
  ],
  "keywords": [
    "response message"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yatendra121/qnx.git"
  },
  "main": "./dist/message.cjs",
  "module": "./dist/message.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/message.cjs",
      "import": "./dist/message.mjs"
    }
  },
  "unpkg": "./index.iife.js",
  "jsdelivr": "./index.iife.js",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build && dts-bundle-generator --config ./dts-bundle-generator.config.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint:scripts": "eslint . --ext .ts",
    "format:scripts": "prettier . --write",
    "format": "npm run format:scripts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "vite": "^8.0.13"
  }
}
